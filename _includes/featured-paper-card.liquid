{% assign featured = site.data.publications | where: "featured", true %}
{% if featured.size > 0 %}
  {% for paper in featured limit: 1 %}
  <div class="publication-card featured-publication-card inline-featured-paper">
    <p class="pub-label">Featured Paper</p>
    <h3>{{ paper.title }}</h3>
    <p class="pub-meta">{{ paper.authors }}</p>
    <p class="pub-venue">{{ paper.venue }}{% if paper.year %}, {{ paper.year }}{% endif %}</p>
    {% if paper.summary %}
    <p class="pub-summary">{{ paper.summary }}</p>
    {% endif %}
    <p class="pub-links">
      {% if paper.paper %}<a href="{{ paper.paper }}">Paper</a>{% endif %}
      {% if paper.doi %}<a href="https://doi.org/{{ paper.doi }}">DOI</a>{% endif %}
      {% if paper.arxiv %}<a href="https://arxiv.org/abs/{{ paper.arxiv }}">arXiv</a>{% endif %}
      {% if paper.thesis %}<a href="{{ paper.thesis }}">Thesis</a>{% endif %}
      {% if paper.github %}<a href="{{ paper.github }}">GitHub</a>{% endif %}
      {% if paper.zenodo %}<a href="{{ paper.zenodo }}">Zenodo</a>{% endif %}
    </p>
  </div>
  {% endfor %}
{% endif %}
